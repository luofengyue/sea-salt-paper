<view class="page">
  <view class="phase-banner">
    <view class="phase-row">
      <text class="phase-title">AI 练习</text>
      <view class="phase-tools">
        <text class="phase-badge">单机桌面</text>
        <view class="sound-setting">
          <text class="sound-label">音效</text>
          <switch class="sound-switch" checked="{{soundEnabled}}" color="#8fd3f4" bindchange="toggleSound"></switch>
        </view>
      </view>
    </view>
    <text class="phase-text">{{phaseText}}</text>
  </view>

  <view class="game-board" wx:if="{{gameState}}">
    <view class="ai-area">
      <view class="ai-token">AI</view>
      <view>
        <text class="area-label">AI 区域</text>
        <text class="area-main">AI 手牌 {{gameState.players[1].hand.length}} 张</text>
      </view>
      <text class="area-side">估分 {{aiScorePreview}} · 组合 {{gameState.players[1].playedPairs.length}} 组</text>
    </view>

    <view class="pile-area">
      <view class="pile-card {{canTakeDiscardA || canChooseDiscardPile ? 'pile-clickable' : ''}} {{canChooseDiscardPile ? 'pile-target' : ''}}" data-pile="A" bindtap="handleDiscardPileTap" hover-class="pile-press">
        <view class="paper-corner"></view>
        <text class="pile-title">弃牌堆 A</text>
        <view class="pile-shape card-shape shape-{{discardPileATop.shape}}" wx:if="{{discardPileATop}}">
          <view class="shape-fold"></view>
          <view class="shape-dot"></view>
          <text class="combo-hint" wx:if="{{discardPileATop.comboHint}}">{{discardPileATop.comboHint}}</text>
          <image class="card-icon-image" src="{{discardPileATop.icon}}" mode="aspectFit" wx:if="{{discardPileATop.icon}}"></image>
          <view class="shape-icon icon-{{discardPileATop.shape}}" wx:else>
            <view class="icon-part icon-main"></view>
            <view class="icon-part icon-accent"></view>
            <view class="icon-part icon-tail"></view>
            <view class="icon-part icon-eye-left"></view>
            <view class="icon-part icon-eye-right"></view>
            <view class="icon-part icon-extra-one"></view>
            <view class="icon-part icon-extra-two"></view>
            <view class="icon-part icon-extra-three"></view>
          </view>
        </view>
        <text class="pile-value">{{discardPileATopName}}</text>
        <text class="pile-mark">A</text>
      </view>

      <view class="deck-card {{canDraw ? 'pile-clickable' : ''}}" bindtap="handleDeckTap" hover-class="pile-press">
        <view class="deck-layer layer-one"></view>
        <view class="deck-layer layer-two"></view>
        <text class="pile-title">牌堆</text>
        <text class="deck-count">{{gameState.deck.length}}</text>
        <text class="pile-desc">剩余张数</text>
      </view>

      <view class="pile-card {{canTakeDiscardB || canChooseDiscardPile ? 'pile-clickable' : ''}} {{canChooseDiscardPile ? 'pile-target' : ''}}" data-pile="B" bindtap="handleDiscardPileTap" hover-class="pile-press">
        <view class="paper-corner"></view>
        <text class="pile-title">弃牌堆 B</text>
        <view class="pile-shape card-shape shape-{{discardPileBTop.shape}}" wx:if="{{discardPileBTop}}">
          <view class="shape-fold"></view>
          <view class="shape-dot"></view>
          <text class="combo-hint" wx:if="{{discardPileBTop.comboHint}}">{{discardPileBTop.comboHint}}</text>
          <image class="card-icon-image" src="{{discardPileBTop.icon}}" mode="aspectFit" wx:if="{{discardPileBTop.icon}}"></image>
          <view class="shape-icon icon-{{discardPileBTop.shape}}" wx:else>
            <view class="icon-part icon-main"></view>
            <view class="icon-part icon-accent"></view>
            <view class="icon-part icon-tail"></view>
            <view class="icon-part icon-eye-left"></view>
            <view class="icon-part icon-eye-right"></view>
            <view class="icon-part icon-extra-one"></view>
            <view class="icon-part icon-extra-two"></view>
            <view class="icon-part icon-extra-three"></view>
          </view>
        </view>
        <text class="pile-value">{{discardPileBTopName}}</text>
        <text class="pile-mark">B</text>
      </view>
    </view>

    <view class="player-area">
      <view class="player-summary">
        <text class="area-label">你的手牌</text>
        <text class="area-side">估分 {{playerScorePreview}} · 颜色奖励 {{gameState.players[0].callColorBonus}}</text>
      </view>

      <view class="hand-list">
        <view class="card-item {{item.selected ? 'selected' : ''}}" wx:for="{{gameState.players[0].hand}}" wx:key="instanceId" data-index="{{index}}" bindtap="toggleHandCard">
          <view class="card-shape shape-{{item.shape}}">
            <view class="shape-fold"></view>
            <view class="shape-dot"></view>
            <text class="combo-hint" wx:if="{{item.comboHint}}">{{item.comboHint}}</text>
            <image class="card-icon-image" src="{{item.icon}}" mode="aspectFit" wx:if="{{item.icon}}"></image>
            <view class="shape-icon icon-{{item.shape}}" wx:else>
              <view class="icon-part icon-main"></view>
              <view class="icon-part icon-accent"></view>
              <view class="icon-part icon-tail"></view>
              <view class="icon-part icon-eye-left"></view>
              <view class="icon-part icon-eye-right"></view>
              <view class="icon-part icon-extra-one"></view>
              <view class="icon-part icon-extra-two"></view>
              <view class="icon-part icon-extra-three"></view>
            </view>
          </view>
          <view class="card-copy">
            <text class="card-name">{{item.name}}</text>
            <text class="card-type">{{item.type}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="temp-area" wx:if="{{gameState.tempDrawCards.length}}">
      <text class="area-label">请选择保留 1 张</text>
      <view class="temp-list">
        <view class="temp-card" wx:for="{{gameState.tempDrawCards}}" wx:key="instanceId" data-index="{{index}}" bindtap="chooseTempCard">
          <view class="card-shape shape-{{item.shape}}">
            <view class="shape-fold"></view>
            <view class="shape-dot"></view>
            <text class="combo-hint" wx:if="{{item.comboHint}}">{{item.comboHint}}</text>
            <image class="card-icon-image" src="{{item.icon}}" mode="aspectFit" wx:if="{{item.icon}}"></image>
            <view class="shape-icon icon-{{item.shape}}" wx:else>
              <view class="icon-part icon-main"></view>
              <view class="icon-part icon-accent"></view>
              <view class="icon-part icon-tail"></view>
              <view class="icon-part icon-eye-left"></view>
              <view class="icon-part icon-eye-right"></view>
              <view class="icon-part icon-extra-one"></view>
              <view class="icon-part icon-extra-two"></view>
              <view class="icon-part icon-extra-three"></view>
            </view>
          </view>
          <view class="card-copy">
            <text class="card-name">{{item.name}}</text>
            <text class="card-type">{{item.type}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="pending-area" wx:if="{{gameState.pendingDiscardCard}}">
      <text class="area-label">待弃牌</text>
      <view class="pending-card">
        <view class="card-shape shape-{{gameState.pendingDiscardCard.shape}}">
          <view class="shape-fold"></view>
          <view class="shape-dot"></view>
          <text class="combo-hint" wx:if="{{gameState.pendingDiscardCard.comboHint}}">{{gameState.pendingDiscardCard.comboHint}}</text>
          <image class="card-icon-image" src="{{gameState.pendingDiscardCard.icon}}" mode="aspectFit" wx:if="{{gameState.pendingDiscardCard.icon}}"></image>
          <view class="shape-icon icon-{{gameState.pendingDiscardCard.shape}}" wx:else>
            <view class="icon-part icon-main"></view>
            <view class="icon-part icon-accent"></view>
            <view class="icon-part icon-tail"></view>
            <view class="icon-part icon-eye-left"></view>
            <view class="icon-part icon-eye-right"></view>
            <view class="icon-part icon-extra-one"></view>
            <view class="icon-part icon-extra-two"></view>
            <view class="icon-part icon-extra-three"></view>
          </view>
        </view>
        <view class="card-copy">
          <text class="card-name">{{gameState.pendingDiscardCard.name}}</text>
          <text class="card-type">{{gameState.pendingDiscardCard.type}}</text>
        </view>
      </view>
      <view class="pending-actions" wx:if="{{canChooseDiscardPile}}">
        <button class="discard-button" data-pile="A" bindtap="discardPendingCard" hover-class="button-press">弃到 A</button>
        <button class="discard-button" data-pile="B" bindtap="discardPendingCard" hover-class="button-press">弃到 B</button>
      </view>
    </view>

    <view class="pending-area" wx:if="{{canChooseCrabPile}}">
      <text class="area-label">螃蟹组合效果</text>
      <text class="pending-card-name" wx:if="{{!crabSelectedPile}}">先选择一个弃牌堆</text>
      <text class="pending-card-name" wx:else>从弃牌堆 {{crabSelectedPile}} 选择 1 张</text>

      <view class="crab-pile-actions" wx:if="{{!crabSelectedPile}}">
        <button class="crab-pile-button {{gameState.discardPileA.length ? '' : 'disabled'}}" disabled="{{!gameState.discardPileA.length}}" data-pile="A" bindtap="selectCrabPile" hover-class="button-press">
          <text class="crab-pile-title">弃牌堆 A</text>
          <text class="crab-pile-count">{{gameState.discardPileA.length}} 张</text>
        </button>
        <button class="crab-pile-button {{gameState.discardPileB.length ? '' : 'disabled'}}" disabled="{{!gameState.discardPileB.length}}" data-pile="B" bindtap="selectCrabPile" hover-class="button-press">
          <text class="crab-pile-title">弃牌堆 B</text>
          <text class="crab-pile-count">{{gameState.discardPileB.length}} 张</text>
        </button>
      </view>

      <view class="crab-selected-pile" wx:else>
        <button class="crab-back-button" bindtap="resetCrabPileSelection" hover-class="button-press">重新选择弃牌堆</button>
        <view class="crab-card-list">
          <button class="small-card" wx:for="{{crabSelectedPileCards}}" wx:key="instanceId" data-index="{{index}}" bindtap="takeCrabEffectCard" hover-class="button-press">{{item.name}}</button>
        </view>
      </view>
    </view>

    <view class="action-area">
      <button class="action-button {{canPlayPair ? '' : 'disabled'}}" disabled="{{!canPlayPair}}" bindtap="playPair" hover-class="button-press"><text class="action-icon">◇</text>打出组合</button>
      <button class="action-button danger {{canCall ? '' : 'disabled'}}" disabled="{{!canCall}}" bindtap="stopRound" hover-class="button-press"><text class="action-icon">!</text>立即停止</button>
      <button class="action-button accent {{canCall ? '' : 'disabled'}}" disabled="{{!canCall}}" bindtap="callLastChance" hover-class="button-press"><text class="action-icon">★</text>最后机会</button>
      <button class="action-button {{canAct ? '' : 'disabled'}}" disabled="{{!canAct}}" bindtap="endTurn" hover-class="button-press"><text class="action-icon">→</text>结束回合<text class="countdown-badge" wx:if="{{isEndTurnCountdownActive}}">{{endTurnCountdown}}</text></button>
    </view>

    <view class="log-area">
      <text class="area-label">最近操作</text>
      <text class="log-item" wx:for="{{recentLogs}}" wx:key="*this">{{item}}</text>
    </view>
  </view>
</view>
