.page {
  height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.07) 0, rgba(47, 142, 188, 0.07) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #edf8f7 48%, #f7fbf6 100%);
}

.header {
  margin-bottom: 30rpx;
  padding: 8rpx 8rpx 0;
}

.kicker {
  display: block;
  color: #2f8ebc;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #174a63;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.18;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: #7b8794;
  font-size: 28rpx;
  line-height: 1.5;
}

.card-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.card-item {
  min-height: 430rpx;
  padding: 14rpx;
  border: 4rpx solid #ffffff;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fbf6 100%);
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(23, 74, 99, 0.09);
}

.card-art {
  height: 168rpx;
  position: relative;
  margin-bottom: 16rpx;
  border-radius: 14rpx;
  background: #174a63;
  overflow: hidden;
}

.art-fold {
  position: absolute;
  width: 0;
  height: 0;
  border-style: solid;
}

.fold-main {
  left: 20rpx;
  top: 24rpx;
  border-width: 0 82rpx 102rpx 0;
  border-color: transparent #2f8ebc transparent transparent;
}

.fold-light {
  right: 18rpx;
  top: 24rpx;
  border-width: 102rpx 0 0 82rpx;
  border-color: transparent transparent transparent #bee9e8;
}

.fold-coral {
  left: 82rpx;
  top: 74rpx;
  border-width: 0 36rpx 48rpx 36rpx;
  border-color: transparent transparent #f26d5b transparent;
}

.art-name {
  position: absolute;
  left: 18rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.card-name {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-score {
  min-width: 78rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 40rpx;
  text-align: center;
}

.card-meta,
.card-effect {
  display: block;
  margin-top: 12rpx;
}

.card-effect {
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f7fbf6;
  box-sizing: border-box;
}

.meta-label,
.effect-label {
  display: block;
  color: #8a94a6;
  font-size: 21rpx;
  line-height: 1.4;
}

.meta-value,
.effect-text {
  display: block;
  margin-top: 4rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-value {
  display: inline-block;
  min-width: 72rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: center;
  box-sizing: border-box;
}

.home-button {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
  border-radius: 16rpx;
  background: #2f8ebc;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  box-shadow: 0 16rpx 34rpx rgba(47, 142, 188, 0.2);
}

.home-button::after {
  border: none;
}

.button-press {
  opacity: 0.86;
  transform: scale(0.99);
}
