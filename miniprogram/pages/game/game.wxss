.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 36rpx 32rpx 56rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.07) 0, rgba(47, 142, 188, 0.07) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #edf8f7 46%, #f7fbf6 100%);
}

.phase-banner {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid rgba(23, 74, 99, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
  box-shadow: 0 16rpx 36rpx rgba(23, 74, 99, 0.08);
}

.phase-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.phase-title {
  display: block;
  color: #174a63;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.phase-badge {
  min-width: 120rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
  box-sizing: border-box;
}

.phase-tools {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  flex-shrink: 0;
}

.sound-setting {
  height: 42rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.sound-label {
  color: #5f8196;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.sound-switch {
  transform: scale(0.68);
  transform-origin: right center;
}

.phase-text {
  display: block;
  margin-top: 16rpx;
  color: #2f8ebc;
  font-size: 27rpx;
  line-height: 1.55;
}

.game-board {
  width: 100%;
}

.ai-area,
.player-area,
.action-area,
.temp-area,
.pending-area,
.log-area {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(23, 74, 99, 0.07);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx rgba(23, 74, 99, 0.07);
}

.ai-area {
  display: grid;
  grid-template-columns: 64rpx 1fr auto;
  align-items: center;
  column-gap: 18rpx;
}

.ai-token {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #174a63;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(23, 74, 99, 0.18);
}

.player-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.area-label {
  display: block;
  color: #7b8794;
  font-size: 24rpx;
  line-height: 1.4;
}

.area-main {
  display: block;
  margin-top: 6rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.area-side {
  color: #174a63;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
}

.pile-area {
  display: grid;
  grid-template-columns: 1fr 1.12fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(190, 233, 232, 0.38);
  box-sizing: border-box;
}

.pile-card,
.deck-card {
  position: relative;
  min-height: 184rpx;
  padding: 20rpx 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.94);
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 16rpx 30rpx rgba(23, 74, 99, 0.11);
}

.pile-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.deck-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #174a63;
  color: #ffffff;
}

.paper-corner {
  position: absolute;
  right: 0;
  top: 0;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 46rpx 46rpx 0;
  border-color: transparent #bee9e8 transparent transparent;
}

.deck-layer {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  height: 28rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.14);
}

.layer-one {
  top: 22rpx;
}

.layer-two {
  top: 34rpx;
}

.pile-clickable {
  border-color: #2f8ebc;
  box-shadow: 0 18rpx 34rpx rgba(47, 142, 188, 0.18);
}

.pile-target {
  background: #eefaf9;
}

.deck-card.pile-clickable {
  border-color: #f2c94c;
}

.pile-press,
.button-press {
  opacity: 0.86;
  transform: scale(0.98);
}

.pile-title {
  position: relative;
  z-index: 1;
  display: block;
  color: #7b8794;
  font-size: 22rpx;
  line-height: 1.35;
}

.deck-card .pile-title,
.deck-card .pile-desc {
  color: rgba(255, 255, 255, 0.78);
}

.pile-value {
  position: relative;
  z-index: 1;
  display: block;
  min-height: 48rpx;
  margin-top: 10rpx;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.pile-shape {
  width: 64rpx;
  height: 64rpx;
  margin: 12rpx auto 0;
  border-radius: 18rpx;
}

.pile-shape .shape-symbol {
  font-size: 25rpx;
}

.pile-shape .shape-icon {
  transform: scale(0.82);
}

.pile-shape .card-icon-image {
  width: 58rpx;
  height: 58rpx;
}

.pile-shape .shape-fold {
  top: 6rpx;
  right: 6rpx;
  width: 18rpx;
  height: 18rpx;
  border-radius: 6rpx 6rpx 6rpx 2rpx;
}

.pile-shape .shape-dot {
  left: 10rpx;
  bottom: 10rpx;
  width: 8rpx;
  height: 8rpx;
}

.pile-mark {
  position: absolute;
  left: 16rpx;
  bottom: 14rpx;
  color: rgba(23, 74, 99, 0.15);
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.deck-count {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.1;
}

.pile-desc {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.hand-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.card-item,
.temp-card {
  min-height: 166rpx;
  padding: 18rpx 16rpx;
  border: 4rpx solid #ffffff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #f6fbf8 100%);
  box-sizing: border-box;
  box-shadow: 0 12rpx 26rpx rgba(23, 74, 99, 0.08);
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-item.selected {
  background: #fff8ed;
  border-color: #f2c94c;
  transform: translateY(-6rpx);
}

.card-shape {
  width: 84rpx;
  height: 84rpx;
  flex-shrink: 0;
  border-radius: 28rpx;
  background: #bee9e8;
  color: #174a63;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 -7rpx 0 rgba(23, 74, 99, 0.06);
}

.shape-fold {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 8rpx 8rpx 8rpx 2rpx;
  background: rgba(255, 255, 255, 0.52);
  transform: rotate(12deg);
}

.shape-dot {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
}

.shape-symbol {
  position: relative;
  z-index: 1;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1;
}

.shape-icon {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  color: inherit;
}

.card-icon-image {
  position: relative;
  z-index: 1;
  width: 76rpx;
  height: 76rpx;
  display: block;
}

.combo-hint {
  position: absolute;
  left: 4rpx;
  top: 4rpx;
  z-index: 3;
  min-width: 34rpx;
  max-width: 56rpx;
  height: 24rpx;
  padding: 0 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #24485f;
  font-size: 16rpx;
  font-weight: 800;
  line-height: 24rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 3rpx 8rpx rgba(80, 150, 190, 0.14);
}

.pile-shape .combo-hint {
  left: 3rpx;
  top: 3rpx;
  min-width: 34rpx;
  max-width: 54rpx;
  height: 22rpx;
  padding: 0 5rpx;
  font-size: 15rpx;
  line-height: 22rpx;
}

.icon-part {
  position: absolute;
  display: block;
  box-sizing: border-box;
}

.icon-main,
.icon-accent,
.icon-tail,
.icon-extra-one,
.icon-extra-two,
.icon-extra-three {
  background: currentColor;
}

.icon-eye-left,
.icon-eye-right {
  width: 5rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: #174a63;
}

.icon-crab .icon-main {
  left: 9rpx;
  top: 18rpx;
  width: 28rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 14rpx 14rpx;
}

.icon-crab .icon-eye-left {
