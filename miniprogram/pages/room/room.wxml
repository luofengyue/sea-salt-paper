<view class="page">
  <view class="header">
    <text class="kicker">Friend Room</text>
    <text class="title">房间等待</text>
    <view class="room-ticket">
      <text class="ticket-label">房间号</text>
      <text class="room-number">{{roomNumber}}</text>
    </view>
  </view>

  <view class="player-list">
    <view class="player-item" wx:for="{{players}}" wx:key="seat">
      <view class="player-avatar {{item.active ? 'active-avatar' : ''}}">{{index + 1}}</view>
      <view class="player-main">
        <text class="player-seat">{{item.seat}}</text>
        <text class="player-name {{item.active ? 'active' : ''}}">{{item.name}}</text>
      </view>
      <text class="player-status" wx:if="{{item.status}}">{{item.status}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="action-button" bindtap="showInviteTip" hover-class="button-press"><text class="action-icon">+</text>邀请好友</button>
    <button class="action-button primary" bindtap="startGame" hover-class="button-press"><text class="action-icon">▶</text>开始游戏</button>
    <button class="action-button secondary" bindtap="goHome" hover-class="button-press"><text class="action-icon">⌂</text>返回首页</button>
  </view>
</view>
