.page {
  min-height: 100vh;
  padding: 72rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.header {
  margin-bottom: 36rpx;
}

.title {
  display: block;
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #2f80ed;
  font-size: 28rpx;
  line-height: 1.5;
}

.result-card,
.pair-card,
.empty {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
  margin-bottom: 28rpx;
}

.score-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
}

.player-name {
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
}

.score-info {
  text-align: right;
}

.round-score,
.total-score,
.pair-line,
.empty-text {
  display: block;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.6;
}

.total-score {
  color: #2f80ed;
  font-weight: 600;
}

.section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-button {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.action-button::after {
  border: none;
}

.action-button.primary {
  background: #2f80ed;
  color: #ffffff;
}
