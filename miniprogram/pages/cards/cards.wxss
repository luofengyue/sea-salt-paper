.page {
  height: 100vh;
  padding: 48rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.header {
  margin-bottom: 36rpx;
}

.title {
  display: block;
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.card-item {
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.card-name {
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.4;
}

.card-score {
  min-width: 96rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #e8f1ff;
  color: #2f80ed;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 44rpx;
  text-align: center;
}

.card-meta,
.card-effect {
  display: flex;
  margin-top: 14rpx;
}

.meta-label,
.effect-label {
  width: 72rpx;
  flex-shrink: 0;
  color: #8a94a6;
  font-size: 26rpx;
  line-height: 1.6;
}

.meta-value,
.effect-text {
  flex: 1;
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.6;
}

.home-button {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
}

.home-button::after {
  border: none;
}
