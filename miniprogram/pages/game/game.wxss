.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 36rpx 32rpx 56rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.07) 0, rgba(47, 142, 188, 0.07) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #edf8f7 46%, #f7fbf6 100%);
}

.phase-banner {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 26rpx 28rpx;
  border: 2rpx solid rgba(23, 74, 99, 0.08);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.82);
  box-sizing: border-box;
  box-shadow: 0 16rpx 36rpx rgba(23, 74, 99, 0.08);
}

.phase-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.phase-title {
  display: block;
  color: #174a63;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.25;
}

.phase-badge {
  min-width: 120rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 42rpx;
  text-align: center;
  box-sizing: border-box;
}

.phase-text {
  display: block;
  margin-top: 16rpx;
  color: #2f8ebc;
  font-size: 27rpx;
  line-height: 1.55;
}

.game-board {
  width: 100%;
}

.ai-area,
.player-area,
.action-area,
.temp-area,
.pending-area,
.log-area {
  width: 100%;
  margin-bottom: 24rpx;
  padding: 24rpx;
  border: 2rpx solid rgba(23, 74, 99, 0.07);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.86);
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx rgba(23, 74, 99, 0.07);
}

.ai-area {
  display: grid;
  grid-template-columns: 64rpx 1fr auto;
  align-items: center;
  column-gap: 18rpx;
}

.ai-token {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #174a63;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 64rpx;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(23, 74, 99, 0.18);
}

.player-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.area-label {
  display: block;
  color: #7b8794;
  font-size: 24rpx;
  line-height: 1.4;
}

.area-main {
  display: block;
  margin-top: 6rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.35;
}

.area-side {
  color: #174a63;
  font-size: 24rpx;
  line-height: 1.4;
  text-align: right;
}

.pile-area {
  display: grid;
  grid-template-columns: 1fr 1.12fr 1fr;
  gap: 18rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(190, 233, 232, 0.38);
  box-sizing: border-box;
}

.pile-card,
.deck-card {
  position: relative;
  min-height: 184rpx;
  padding: 20rpx 16rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.94);
  border-radius: 16rpx;
  background: #ffffff;
  box-sizing: border-box;
  text-align: center;
  overflow: hidden;
  box-shadow: 0 16rpx 30rpx rgba(23, 74, 99, 0.11);
}

.pile-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.deck-card {
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #174a63;
  color: #ffffff;
}

.paper-corner {
  position: absolute;
  right: 0;
  top: 0;
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 0 46rpx 46rpx 0;
  border-color: transparent #bee9e8 transparent transparent;
}

.deck-layer {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  height: 28rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.14);
}

.layer-one {
  top: 22rpx;
}

.layer-two {
  top: 34rpx;
}

.pile-clickable {
  border-color: #2f8ebc;
  box-shadow: 0 18rpx 34rpx rgba(47, 142, 188, 0.18);
}

.pile-target {
  background: #eefaf9;
}

.deck-card.pile-clickable {
  border-color: #f2c94c;
}

.pile-press,
.button-press {
  opacity: 0.86;
  transform: scale(0.98);
}

.pile-title {
  position: relative;
  z-index: 1;
  display: block;
  color: #7b8794;
  font-size: 22rpx;
  line-height: 1.35;
}

.deck-card .pile-title,
.deck-card .pile-desc {
  color: rgba(255, 255, 255, 0.78);
}

.pile-value {
  position: relative;
  z-index: 1;
  display: block;
  min-height: 48rpx;
  margin-top: 20rpx;
  color: #1f2933;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.pile-mark {
  position: absolute;
  left: 16rpx;
  bottom: 14rpx;
  color: rgba(23, 74, 99, 0.15);
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1;
}

.deck-count {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 14rpx;
  color: #ffffff;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.1;
}

.pile-desc {
  position: relative;
  z-index: 1;
  display: block;
  margin-top: 8rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.hand-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}

.card-item,
.temp-card {
  min-height: 154rpx;
  padding: 20rpx;
  border: 4rpx solid #ffffff;
  border-radius: 16rpx;
  background: linear-gradient(180deg, #ffffff 0%, #f7fbf6 100%);
  box-sizing: border-box;
  box-shadow: 0 12rpx 26rpx rgba(23, 74, 99, 0.08);
}

.card-item.selected {
  background: #eefaf9;
  border-color: #2f8ebc;
  transform: translateY(-6rpx);
}

.card-name {
  display: block;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.35;
}

.card-type {
  display: inline-block;
  min-width: 68rpx;
  margin-top: 12rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 21rpx;
  line-height: 1.3;
  text-align: center;
  box-sizing: border-box;
}

.temp-list,
.pending-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.temp-card {
  flex: 1;
}

.pending-area {
  border-color: rgba(242, 201, 76, 0.32);
  background: rgba(255, 255, 255, 0.92);
}

.pending-card-name {
  display: block;
  margin-top: 12rpx;
  color: #174a63;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.35;
}

.crab-piles {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  margin-top: 20rpx;
}

.crab-pile {
  min-height: 120rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #f7fbf6;
  box-sizing: border-box;
}

.small-card {
  width: 100%;
  min-height: 58rpx;
  margin-top: 12rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 24rpx;
  line-height: 58rpx;
  box-shadow: 0 8rpx 18rpx rgba(23, 74, 99, 0.06);
}

.small-card::after {
  border: none;
}

.empty-pile {
  display: block;
  margin-top: 12rpx;
  color: #9ca3af;
  font-size: 24rpx;
  line-height: 1.4;
}

.action-area {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.action-button {
  width: 100%;
  height: 78rpx;
  border-radius: 14rpx;
  background: #ffffff;
  color: #174a63;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 78rpx;
  box-shadow: 0 10rpx 22rpx rgba(23, 74, 99, 0.08);
}

.action-icon {
  display: inline-block;
  width: 34rpx;
  height: 34rpx;
  margin-right: 8rpx;
  border-radius: 10rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
  vertical-align: 2rpx;
}

.danger .action-icon,
.accent .action-icon {
  background: rgba(255, 255, 255, 0.86);
}

.action-button::after {
  border: none;
}

.action-button.accent {
  background: #f2c94c;
  color: #174a63;
}

.action-button.danger {
  background: #f26d5b;
  color: #ffffff;
}

.action-button.disabled {
  background: rgba(229, 231, 235, 0.78);
  color: #9ca3af;
  box-shadow: none;
}

.log-area {
  padding-bottom: 18rpx;
}

.log-item {
  display: block;
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 23rpx;
  line-height: 1.5;
}
