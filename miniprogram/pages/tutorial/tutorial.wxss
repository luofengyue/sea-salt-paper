.page {
  height: 100vh;
  padding: 48rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.header {
  margin-bottom: 36rpx;
}

.title {
  display: block;
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.section-text {
  display: block;
  color: #4b5563;
  font-size: 28rpx;
  line-height: 1.7;
}

.home-button {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
  border-radius: 12rpx;
  background: #2f80ed;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
}

.home-button::after {
  border: none;
}
