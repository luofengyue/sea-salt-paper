<view class="page">
  <view class="top-row">
    <button class="hall-button" bindtap="goToLobby" hover-class="button-press">‹ 桌游大厅</button>
    <view class="sound-setting">
      <text class="sound-label">音效</text>
      <switch class="sound-switch" checked="{{soundEnabled}}" color="#8fd3f4" bindchange="toggleSound"></switch>
    </view>
  </view>

  <view class="sea-surface">
    <view class="wave-layer"></view>
    <view class="paper-mark">
      <view class="paper-shadow"></view>
      <view class="fold fold-blue"></view>
      <view class="fold fold-mint"></view>
      <view class="fold fold-coral"></view>
    </view>
    <view class="title-block">
      <text class="kicker">Sea Salt & Paper</text>
      <text class="title">海盐折纸</text>
      <text class="subtitle">轻量单机练习版</text>
    </view>
  </view>

  <view class="lobby-status">
    <view class="status-item">
      <text class="status-value">AI</text>
      <text class="status-label">练习模式</text>
    </view>
    <view class="status-divider"></view>
    <view class="status-item">
      <text class="status-value">40</text>
      <text class="status-label">目标分</text>
    </view>
    <view class="status-divider"></view>
    <view class="status-item">
      <text class="status-value">5</text>
      <text class="status-label">页面入口</text>
    </view>
  </view>

  <view class="actions">
    <button class="action-button" bindtap="goToGame" hover-class="button-press">
      <text class="button-icon">AI</text>
      <text class="button-label">和 AI 练习</text>
      <text class="button-arrow">›</text>
    </button>
    <button class="action-button" bindtap="goToRoom" hover-class="button-press">
      <text class="button-icon">+</text>
      <text class="button-label">创建好友房</text>
      <text class="button-arrow">›</text>
    </button>
    <button class="action-button" bindtap="showJoinRoomTip" hover-class="button-press">
      <text class="button-icon">#</text>
      <text class="button-label">加入房间</text>
      <text class="button-arrow">›</text>
    </button>
    <button class="action-button" bindtap="goToTutorial" hover-class="button-press">
      <text class="button-icon">?</text>
      <text class="button-label">规则教程</text>
      <text class="button-arrow">›</text>
    </button>
    <button class="action-button" bindtap="goToCards" hover-class="button-press">
      <text class="button-icon">◇</text>
      <text class="button-label">牌库图鉴</text>
      <text class="button-arrow">›</text>
    </button>
  </view>
</view>
