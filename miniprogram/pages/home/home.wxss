.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  padding: 44rpx 40rpx 56rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.08) 0, rgba(47, 142, 188, 0.08) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #eef8f7 52%, #f7fbf6 100%);
}

.top-row {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.hall-button {
  width: 190rpx;
  height: 54rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #174a63;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 54rpx;
  text-align: center;
  box-shadow: 0 10rpx 22rpx rgba(23, 74, 99, 0.08);
}

.hall-button::after {
  border: none;
}

.sound-setting {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
}

.sound-label {
  color: #5f8196;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1;
}

.sound-switch {
  transform: scale(0.74);
  transform-origin: right center;
}

.sea-surface {
  width: 100%;
  min-height: 360rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  position: relative;
  padding-bottom: 36rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.wave-layer {
  position: absolute;
  left: -44rpx;
  right: -44rpx;
  bottom: 0;
  height: 124rpx;
  background:
    linear-gradient(135deg, transparent 0, transparent 24rpx, rgba(190, 233, 232, 0.78) 24rpx, rgba(190, 233, 232, 0.78) 48rpx, transparent 48rpx, transparent 72rpx),
    linear-gradient(45deg, transparent 0, transparent 30rpx, rgba(47, 142, 188, 0.22) 30rpx, rgba(47, 142, 188, 0.22) 58rpx, transparent 58rpx, transparent 88rpx);
  opacity: 0.86;
}

.paper-mark {
  width: 210rpx;
  height: 172rpx;
  position: relative;
  margin-left: 8rpx;
  margin-bottom: 30rpx;
  z-index: 1;
}

.paper-shadow {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 6rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(23, 74, 99, 0.18);
  box-shadow: 0 12rpx 24rpx rgba(23, 74, 99, 0.12);
}

.fold {
  position: absolute;
  box-sizing: border-box;
  border-style: solid;
}

.fold-blue {
  left: 10rpx;
  top: 22rpx;
  border-width: 0 92rpx 122rpx 0;
  border-color: transparent #2f8ebc transparent transparent;
}

.fold-mint {
  left: 102rpx;
  top: 22rpx;
  border-width: 122rpx 0 0 92rpx;
  border-color: transparent transparent transparent #bee9e8;
}

.fold-coral {
  left: 62rpx;
  top: 74rpx;
  border-width: 0 52rpx 70rpx 52rpx;
  border-color: transparent transparent #f26d5b transparent;
  opacity: 0.92;
}

.title-block {
  position: relative;
  z-index: 1;
}

.title {
  display: block;
  margin-top: 10rpx;
  color: #1f2933;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1.16;
}

.kicker {
  display: block;
  color: #2f8ebc;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  margin-top: 18rpx;
  color: #174a63;
  font-size: 28rpx;
  line-height: 1.5;
}

.lobby-status {
  width: 100%;
  min-height: 116rpx;
  display: flex;
  align-items: center;
  margin: 12rpx 0 28rpx;
  padding: 18rpx 0;
  border: 2rpx solid rgba(23, 74, 99, 0.08);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.76);
  box-sizing: border-box;
  box-shadow: 0 16rpx 36rpx rgba(23, 74, 99, 0.08);
}

.status-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.status-value {
  color: #174a63;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.2;
}

.status-label {
  margin-top: 8rpx;
  color: #7b8794;
  font-size: 22rpx;
  line-height: 1.35;
}

.status-divider {
  width: 2rpx;
  height: 54rpx;
  background: rgba(23, 74, 99, 0.08);
}

.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-button {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  padding: 0 28rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #1f2933;
  font-size: 29rpx;
  font-weight: 500;
  line-height: 1;
  text-align: left;
  box-shadow: 0 12rpx 28rpx rgba(23, 74, 99, 0.09);
  box-sizing: border-box;
}

.action-button.primary {
  background: #2f8ebc;
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(47, 142, 188, 0.24);
}

.button-icon {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 22rpx;
  border-radius: 12rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-align: center;
  box-shadow: inset 0 -4rpx 0 rgba(23, 74, 99, 0.08);
}

.primary .button-icon {
  background: #ffffff;
  color: #2f8ebc;
}

.button-label {
  flex: 1;
  line-height: 1.3;
}

.button-arrow {
  color: #f26d5b;
  font-size: 44rpx;
  line-height: 1;
}

.primary .button-arrow {
  color: #f2c94c;
}

.button-press {
  background: #8fd3f4;
  color: #ffffff;
  opacity: 0.92;
  transform: scale(0.99);
  box-shadow: 0 16rpx 34rpx rgba(111, 185, 223, 0.28);
}

/* Macaron blue palette */
.page {
  background:
    linear-gradient(135deg, rgba(143, 211, 244, 0.16) 0, rgba(143, 211, 244, 0.16) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f4fbff 0%, #e3f6ff 52%, #f8fdff 100%);
}

.hall-button,
.lobby-status,
.action-button {
  box-shadow: 0 12rpx 28rpx rgba(80, 150, 190, 0.12);
}

.hall-button,
.subtitle,
.status-value {
  color: #24485f;
}

.title {
  color: #203f55;
}

.kicker {
  color: #3f8fbb;
}

.wave-layer {
  background:
    linear-gradient(135deg, transparent 0, transparent 24rpx, rgba(198, 240, 255, 0.9) 24rpx, rgba(198, 240, 255, 0.9) 48rpx, transparent 48rpx, transparent 72rpx),
    linear-gradient(45deg, transparent 0, transparent 30rpx, rgba(143, 211, 244, 0.32) 30rpx, rgba(143, 211, 244, 0.32) 58rpx, transparent 58rpx, transparent 88rpx);
}

.paper-shadow {
  background: rgba(80, 150, 190, 0.14);
  box-shadow: 0 12rpx 24rpx rgba(80, 150, 190, 0.12);
}

.fold-blue {
  border-color: transparent #8fd3f4 transparent transparent;
}

.fold-mint {
  border-color: transparent transparent transparent #c6f0ff;
}

.fold-coral {
  border-color: transparent transparent #b9dcff transparent;
}

.lobby-status {
  border-color: rgba(106, 174, 216, 0.14);
  background: rgba(255, 255, 255, 0.82);
}

.status-label {
  color: #5f8196;
}

.status-divider {
  background: rgba(106, 174, 216, 0.18);
}

.action-button {
  color: #24485f;
}

.action-button.primary {
  background: #8fd3f4;
  color: #ffffff;
  box-shadow: 0 16rpx 34rpx rgba(111, 185, 223, 0.28);
}

.button-icon {
  background: #d8f3ff;
  color: #24485f;
  box-shadow: inset 0 -4rpx 0 rgba(80, 150, 190, 0.08);
}

.primary .button-icon {
  color: #3f8fbb;
}

.button-arrow,
.primary .button-arrow {
  color: #7bbdf0;
}

.button-press .button-icon {
  background: #ffffff;
  color: #3f8fbb;
}

.button-press .button-arrow {
  color: #ffffff;
}
