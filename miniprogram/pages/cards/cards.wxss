@import "../../styles/cardIcons.wxss";

.page {
  height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.07) 0, rgba(47, 142, 188, 0.07) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #edf8f7 48%, #f7fbf6 100%);
}

.header {
  margin-bottom: 30rpx;
  padding: 8rpx 8rpx 0;
}

.kicker {
  display: block;
  color: #2f8ebc;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #174a63;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.18;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: #7b8794;
  font-size: 28rpx;
  line-height: 1.5;
}

.card-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.card-item {
  min-height: 430rpx;
  padding: 14rpx;
  border: 4rpx solid #ffffff;
  border-radius: 22rpx;
  background: linear-gradient(180deg, #fffdf8 0%, #f7fbf6 100%);
  box-sizing: border-box;
  box-shadow: 0 14rpx 30rpx rgba(23, 74, 99, 0.08);
}

.card-art {
  height: 168rpx;
  position: relative;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: #bee9e8;
  color: #174a63;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 0 -10rpx 0 rgba(23, 74, 99, 0.05);
}

.shape-soft {
  position: absolute;
  width: 118rpx;
  height: 118rpx;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.62);
  transform: rotate(-8deg);
}

.shape-fold {
  position: absolute;
  top: 26rpx;
  right: 34rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 12rpx 12rpx 12rpx 2rpx;
  background: rgba(255, 255, 255, 0.56);
  transform: rotate(12deg);
}

.shape-dot {
  position: absolute;
  left: 42rpx;
  top: 46rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
}

.card-art .shape-icon {
  transform: scale(1.45);
}

.card-art .card-icon-image {
  position: relative;
  z-index: 1;
  width: 150rpx;
  height: 150rpx;
  display: block;
}

.combo-hint {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  z-index: 3;
  min-width: 56rpx;
  max-width: 92rpx;
  height: 34rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #24485f;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  box-sizing: border-box;
  box-shadow: 0 5rpx 12rpx rgba(80, 150, 190, 0.16);
}

.art-name {
  position: absolute;
  left: 18rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.card-art.shape-crab {
  border-radius: 30rpx 30rpx 18rpx 18rpx;
  background: #ffd8d2;
  color: #b84a3d;
}

.card-art.shape-boat {
  border-radius: 14rpx 34rpx 20rpx 34rpx;
  background: #d8f1f5;
  color: #2f8ebc;
}

.card-art.shape-fish {
  border-radius: 36rpx 18rpx 36rpx 18rpx;
  background: #d8efe5;
  color: #377f70;
}

.card-art.shape-shark {
  border-radius: 18rpx 38rpx 18rpx 38rpx;
  background: #dce6f5;
  color: #506b91;
}

.card-art.shape-swimmer {
  border-radius: 999rpx;
  background: #d6edf9;
  color: #2f8ebc;
}

.card-art.shape-mermaid {
  border-radius: 38rpx 14rpx 38rpx 14rpx;
  background: #eadff6;
  color: #7b61a8;
}

.card-art.shape-shell {
  border-radius: 38rpx 38rpx 16rpx 16rpx;
  background: #ffe2bd;
  color: #b37332;
}

.card-art.shape-octopus {
  border-radius: 999rpx 999rpx 26rpx 26rpx;
  background: #f8d7e6;
  color: #aa5279;
}

.card-art.shape-penguin {
  border-radius: 999rpx;
  background: #e2edf0;
  color: #174a63;
}

.card-art.shape-sailor {
  border-radius: 20rpx;
  background: #d7e7ff;
  color: #3d6fa9;
}

.card-art.shape-lighthouse {
  border-radius: 14rpx 14rpx 32rpx 32rpx;
  background: #ffe4dc;
  color: #c75d4d;
}

.card-art.shape-shoal {
  border-radius: 30rpx 16rpx 30rpx 16rpx;
  background: #d7f2ee;
  color: #2f8a80;
}

.card-art.shape-penguin-colony {
  border-radius: 999rpx;
  background: #e5edf5;
  color: #31546b;
}

.card-art.shape-captain {
  border-radius: 18rpx 34rpx 18rpx 34rpx;
  background: #fff0ba;
  color: #946b18;
}

.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  margin-bottom: 14rpx;
}

.card-name {
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-score {
  min-width: 78rpx;
  height: 40rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 40rpx;
  text-align: center;
}

.card-meta,
.card-effect {
  display: block;
  margin-top: 12rpx;
}

.card-effect {
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f7fbf6;
  box-sizing: border-box;
}

.meta-label,
.effect-label {
  display: block;
  color: #8a94a6;
  font-size: 21rpx;
  line-height: 1.4;
}

.meta-value,
.effect-text {
  display: block;
  margin-top: 4rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.5;
}

.meta-value {
  display: inline-block;
  min-width: 72rpx;
  padding: 5rpx 12rpx;
  border-radius: 999rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: center;
  box-sizing: border-box;
}

.home-button {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
  border-radius: 16rpx;
  background: #2f8ebc;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  box-shadow: 0 16rpx 34rpx rgba(47, 142, 188, 0.2);
}

.home-button::after {
  border: none;
}

.button-press {
  opacity: 0.86;
  transform: scale(0.99);
}

/* Macaron blue palette */
.page {
  background:
    linear-gradient(135deg, rgba(143, 211, 244, 0.16) 0, rgba(143, 211, 244, 0.16) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f4fbff 0%, #e3f6ff 48%, #f8fdff 100%);
}

.kicker {
  color: #3f8fbb;
}

.title,
.card-name {
  color: #24485f;
}

.subtitle,
.meta-label,
.effect-label {
  color: #5f8196;
}

.card-item {
  background: linear-gradient(180deg, #ffffff 0%, #f1faff 100%);
  box-shadow: 0 14rpx 30rpx rgba(80, 150, 190, 0.12);
}

.card-art,
.card-score,
.meta-value {
  background: #d8f3ff;
  color: #24485f;
}

.card-effect {
  background: #f1faff;
}

.effect-text,
.meta-value {
  color: #31586f;
}

.home-button {
  background: #8fd3f4;
  box-shadow: 0 16rpx 34rpx rgba(111, 185, 223, 0.28);
}

.card-art.shape-crab,
.card-art.shape-boat,
.card-art.shape-fish,
.card-art.shape-shark,
.card-art.shape-swimmer,
.card-art.shape-mermaid,
.card-art.shape-shell,
.card-art.shape-octopus,
.card-art.shape-penguin,
.card-art.shape-sailor,
.card-art.shape-lighthouse,
.card-art.shape-shoal,
.card-art.shape-penguin-colony,
.card-art.shape-captain {
  background: #d8f3ff;
  color: #347fae;
}

.card-art.shape-shark,
.card-art.shape-penguin,
.card-art.shape-penguin-colony {
  background: #dbeeff;
  color: #3c6797;
}

.card-art.shape-shell,
.card-art.shape-captain {
  background: #e8f6ff;
  color: #3f8fbb;
}
