.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 48rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.phase-banner {
  width: 100%;
  margin-bottom: 28rpx;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.phase-title {
  display: block;
  color: #1f2933;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.phase-text {
  display: block;
  margin-top: 12rpx;
  color: #2f80ed;
  font-size: 28rpx;
  line-height: 1.5;
}

.game-board {
  width: 100%;
}

.ai-area,
.player-area,
.action-area,
.temp-area,
.pending-area,
.log-area {
  width: 100%;
  padding: 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
  margin-bottom: 28rpx;
}

.ai-area,
.player-summary {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.area-label {
  display: block;
  color: #8a94a6;
  font-size: 26rpx;
  line-height: 1.4;
}

.area-main {
  display: block;
  margin-top: 8rpx;
  color: #1f2933;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.4;
}

.area-side {
  color: #6b7280;
  font-size: 26rpx;
  line-height: 1.4;
}

.pile-area {
  display: flex;
  gap: 18rpx;
  margin-bottom: 28rpx;
}

.pile-card,
.deck-card {
  flex: 1;
  min-height: 156rpx;
  padding: 20rpx;
  border: 2rpx solid transparent;
  border-radius: 12rpx;
  background: #ffffff;
  box-sizing: border-box;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.deck-card {
  flex: 1.1;
  background: #1f2933;
}

.pile-clickable {
  border-color: #2f80ed;
}

.pile-target {
  background: #eef6ff;
}

.deck-card.pile-clickable {
  border-color: #68d391;
}

.pile-press {
  opacity: 0.82;
  transform: scale(0.98);
}

.pile-title {
  display: block;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.4;
}

.deck-card .pile-title,
.deck-card .pile-desc {
  color: #d9e2ec;
}

.pile-value {
  display: block;
  margin-top: 22rpx;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.deck-count {
  display: block;
  margin-top: 12rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
}

.pile-desc {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.hand-list {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.card-item {
  width: calc((100% - 18rpx) / 2);
  min-height: 142rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.card-item.selected {
  background: #e8f1ff;
  outline: 4rpx solid #2f80ed;
}

.card-name {
  display: block;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.card-type {
  display: block;
  margin-top: 8rpx;
  color: #8a94a6;
  font-size: 24rpx;
  line-height: 1.4;
}

.card-score {
  display: block;
  margin-top: 8rpx;
  color: #2f80ed;
  font-size: 26rpx;
  line-height: 1.4;
}

.action-area {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.temp-list,
.pending-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.temp-card {
  flex: 1;
  min-height: 136rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.pending-card-name {
  display: block;
  margin-top: 12rpx;
  color: #1f2933;
  font-size: 34rpx;
  font-weight: 700;
}

.crab-piles {
  display: flex;
  gap: 18rpx;
  margin-top: 20rpx;
}

.crab-pile {
  flex: 1;
  min-height: 120rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.small-card {
  width: 100%;
  min-height: 56rpx;
  margin-top: 12rpx;
  border-radius: 8rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 24rpx;
  line-height: 56rpx;
}

.small-card::after {
  border: none;
}

.empty-pile {
  display: block;
  margin-top: 12rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

.action-button {
  width: calc((100% - 18rpx) / 2);
  height: 76rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #1f2933;
  font-size: 26rpx;
  font-weight: 500;
  line-height: 76rpx;
}

.pending-actions .action-button {
  flex: 1;
  width: auto;
}

.action-button::after {
  border: none;
}

.action-button.primary {
  background: #2f80ed;
  color: #ffffff;
}

.action-button.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.log-item {
  display: block;
  margin-top: 12rpx;
  color: #4b5563;
  font-size: 24rpx;
  line-height: 1.5;
}
