.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 120rpx 48rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 72rpx;
}

.title {
  color: #1f2933;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle {
  margin-top: 20rpx;
  color: #6b7280;
  font-size: 28rpx;
  line-height: 1.5;
}

.actions {
  width: 100%;
  max-width: 560rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-button {
  width: 100%;
  height: 92rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 92rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.08);
}

.action-button::after {
  border: none;
}

.action-button.primary {
  background: #2f80ed;
  color: #ffffff;
}
