<view class="page">
  <view class="header">
    <text class="title">房间等待</text>
    <text class="room-number">房间号：{{roomNumber}}</text>
  </view>

  <view class="player-list">
    <view class="player-item" wx:for="{{players}}" wx:key="seat">
      <view class="player-main">
        <text class="player-seat">{{item.seat}}</text>
        <text class="player-name {{item.active ? 'active' : ''}}">{{item.name}}</text>
      </view>
      <text class="player-status" wx:if="{{item.status}}">{{item.status}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="action-button" bindtap="showInviteTip">邀请好友</button>
    <button class="action-button primary" bindtap="startGame">开始游戏</button>
    <button class="action-button secondary" bindtap="goHome">返回首页</button>
  </view>
</view>
