<scroll-view class="page" scroll-y>
  <view class="header">
    <text class="kicker">Card Archive</text>
    <text class="title">牌库图鉴</text>
    <text class="subtitle">海洋折纸卡牌一览</text>
  </view>

  <view class="card-list">
    <view class="card-item" wx:for="{{cards}}" wx:key="id">
      <view class="card-art shape-{{item.shape}}">
        <view class="shape-soft"></view>
        <view class="shape-fold"></view>
        <view class="shape-dot"></view>
        <text class="combo-hint" wx:if="{{item.comboHint}}">{{item.comboHint}}</text>
        <image class="card-icon-image" src="{{item.icon}}" mode="aspectFit" wx:if="{{item.icon}}"></image>
        <view class="shape-icon icon-{{item.shape}}" wx:else>
          <view class="icon-part icon-main"></view>
          <view class="icon-part icon-accent"></view>
          <view class="icon-part icon-tail"></view>
          <view class="icon-part icon-eye-left"></view>
          <view class="icon-part icon-eye-right"></view>
          <view class="icon-part icon-extra-one"></view>
          <view class="icon-part icon-extra-two"></view>
          <view class="icon-part icon-extra-three"></view>
        </view>
        <text class="art-name">{{item.name}}</text>
      </view>
      <view class="card-top">
        <text class="card-name">{{item.name}}</text>
        <text class="card-score">{{item.count}} 张</text>
      </view>
      <view class="card-meta">
        <text class="meta-label">类型</text>
        <text class="meta-value">{{item.type}}</text>
      </view>
      <view class="card-effect">
        <text class="effect-label">效果</text>
        <text class="effect-text">{{item.description}}</text>
      </view>
    </view>
  </view>

  <button class="home-button" bindtap="goHome" hover-class="button-press">返回首页</button>
</scroll-view>
