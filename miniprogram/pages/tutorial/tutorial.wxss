.page {
  height: 100vh;
  padding: 48rpx 32rpx 64rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(47, 142, 188, 0.07) 0, rgba(47, 142, 188, 0.07) 1rpx, transparent 1rpx, transparent 24rpx),
    linear-gradient(180deg, #f6f8f4 0%, #edf8f7 48%, #f7fbf6 100%);
}

.header {
  margin-bottom: 30rpx;
  padding: 8rpx 8rpx 0;
}

.kicker {
  display: block;
  color: #2f8ebc;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
  letter-spacing: 0;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #174a63;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 1.18;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: #7b8794;
  font-size: 28rpx;
  line-height: 1.5;
}

.section {
  position: relative;
  margin-bottom: 20rpx;
  padding: 28rpx 28rpx 28rpx 104rpx;
  border: 2rpx solid rgba(23, 74, 99, 0.07);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  box-sizing: border-box;
  box-shadow: 0 12rpx 30rpx rgba(23, 74, 99, 0.07);
}

.section-index {
  position: absolute;
  left: 24rpx;
  top: 28rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #bee9e8;
  color: #174a63;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: center;
  box-shadow: inset 0 -4rpx 0 rgba(23, 74, 99, 0.08);
}

.section-title {
  display: block;
  margin-bottom: 12rpx;
  color: #1f2933;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.4;
}

.section-text {
  display: block;
  color: #4b5563;
  font-size: 27rpx;
  line-height: 1.7;
}

.home-button {
  width: 100%;
  height: 88rpx;
  margin-top: 40rpx;
  margin-bottom: 32rpx;
  border-radius: 16rpx;
  background: #2f8ebc;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 88rpx;
  box-shadow: 0 16rpx 34rpx rgba(47, 142, 188, 0.2);
}

.home-button::after {
  border: none;
}

.button-press {
  opacity: 0.86;
  transform: scale(0.99);
}
