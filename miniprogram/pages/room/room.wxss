.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  padding: 72rpx 40rpx 64rpx;
  box-sizing: border-box;
  background: #f6f8fb;
}

.header {
  width: 100%;
  margin-bottom: 40rpx;
  text-align: center;
}

.title {
  display: block;
  color: #1f2933;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.3;
}

.room-number {
  display: block;
  margin-top: 18rpx;
  color: #2f80ed;
  font-size: 34rpx;
  font-weight: 600;
  line-height: 1.5;
}

.player-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.player-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 0 28rpx;
  border-radius: 12rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.player-main {
  display: flex;
  align-items: center;
}

.player-seat {
  width: 112rpx;
  color: #8a94a6;
  font-size: 26rpx;
  line-height: 1.5;
}

.player-name {
  color: #4b5563;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 1.5;
}

.player-name.active {
  color: #1f2933;
  font-weight: 700;
}

.player-status {
  color: #18a058;
  font-size: 26rpx;
  line-height: 1.5;
}

.actions {
  width: 100%;
  margin-top: 48rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.action-button {
  width: 100%;
  height: 88rpx;
  border-radius: 12rpx;
  background: #ffffff;
  color: #1f2933;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 88rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 51, 0.06);
}

.action-button::after {
  border: none;
}

.action-button.primary {
  background: #2f80ed;
  color: #ffffff;
}

.action-button.secondary {
  color: #6b7280;
}
